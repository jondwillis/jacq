{
  "name": "jacq",
  "image": "mcr.microsoft.com/devcontainers/rust:1-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb",
        "usernamehw.errorlens"
      ],
      "settings": {
        "rust-analyzer.check.command": "clippy",
        "editor.formatOnSave": true,
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        }
      }
    }
  },

  // Init submodules (vendor/ contains 5 of them — needed for generate-examples.sh
  // and roundtrip conformance tests to have anything to iterate over) and
  // bootstrap supply-chain tooling (cargo-deny) via cargo-binstall so sessions
  // inside the container can run `cargo deny check` without host installs.
  // cargo-vet is not bootstrapped here because cargo-vet is intentionally
  // ungated in CI; install it on-demand with `cargo binstall cargo-vet` if you
  // want to run it locally.
  "postCreateCommand": "git submodule update --init --recursive && curl -L --proto '=https' --tlsv1.2 -sSf https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash && cargo binstall --no-confirm --force cargo-deny",

  "remoteUser": "vscode",
  "mounts": [
    // Persist cargo registry + target across container rebuilds so we don't
    // redownload crates and recompile the world on every rebuild.
    "source=jacq-cargo-cache,target=/usr/local/cargo/registry,type=volume",
    "source=jacq-target-cache,target=${containerWorkspaceFolder}/target,type=volume"
  ]
}
