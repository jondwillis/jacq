{
  "name": "jacq",
  "image": "mcr.microsoft.com/devcontainers/rust:1-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb",
        "usernamehw.errorlens"
      ],
      "settings": {
        "rust-analyzer.check.command": "clippy",
        "editor.formatOnSave": true,
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        }
      }
    }
  },

  // postCreateCommand sequence:
  //   1. init submodules (vendor/ contains 5 of them — needed for generate-examples.sh
  //      and roundtrip conformance tests to have anything to iterate over)
  //   2. bootstrap cargo-binstall + cargo-deny so sessions inside the container
  //      can run `cargo deny check` without host installs. cargo-vet is NOT
  //      bootstrapped here because it is intentionally ungated in CI; install
  //      on-demand with `cargo binstall cargo-vet` if you want to run it locally.
  //   3. `cargo fetch` warm-up: populates the persistent cargo registry volume
  //      with all dep source trees so the first in-container `cargo build` after
  //      a fresh rebuild isn't cold-starting an empty cache. We intentionally use
  //      `cargo fetch` (not `cargo build`) because fetch only downloads tarballs
  //      and does NOT run build scripts or proc-macros — the warm-up step itself
  //      is therefore attack-surface-free, which matters because one of the
  //      reasons this container exists is to contain malicious build-script
  //      execution. See CLAUDE.md for the full sandbox rationale.
  "postCreateCommand": "git submodule update --init --recursive && curl -L --proto '=https' --tlsv1.2 -sSf https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash && cargo binstall --no-confirm --force cargo-deny && cargo fetch",

  "remoteUser": "vscode",
  "mounts": [
    // Persist cargo registry + target across container rebuilds so we don't
    // redownload crates and recompile the world on every rebuild.
    "source=jacq-cargo-cache,target=/usr/local/cargo/registry,type=volume",
    "source=jacq-target-cache,target=${containerWorkspaceFolder}/target,type=volume"
  ]
}
